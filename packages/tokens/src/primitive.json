{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "blue": {
      "100": { "$value": "#dbeafe", "$type": "color" },
      "300": { "$value": "#93c5fd", "$type": "color" },
      "500": { "$value": "#3b82f6", "$type": "color" },
      "700": { "$value": "#1d4ed8", "$type": "color" },
      "900": { "$value": "#1e3a5f", "$type": "color" }
    },
    "neutral": {
      "0":   { "$value": "#ffffff", "$type": "color" },
      "100": { "$value": "#f5f5f5", "$type": "color" },
      "300": { "$value": "#d4d4d4", "$type": "color" },
      "500": { "$value": "#737373", "$type": "color" },
      "700": { "$value": "#404040", "$type": "color" },
      "900": { "$value": "#111111", "$type": "color" }
    }
  },
  "spacing": {
    "1": { "$value": "4px",  "$type": "dimension" },
    "2": { "$value": "8px",  "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "6": { "$value": "24px", "$type": "dimension" },
    "8": { "$value": "32px", "$type": "dimension" }
  },
  "font-size": {
    "sm":   { "$value": "12px", "$type": "dimension" },
    "base": { "$value": "16px", "$type": "dimension" },
    "lg":   { "$value": "20px", "$type": "dimension" },
    "xl":   { "$value": "24px", "$type": "dimension" }
  }
}
