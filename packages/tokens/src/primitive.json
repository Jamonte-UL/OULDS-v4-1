    }
  },
  "blur": {
    "none": {
      "$type": "number",
      "$value": 0
    },
    "sm": {
      "$type": "number",
      "$value": 4
    },
    "md": {
      "$type": "number",
      "$value": 8
    },
    "lg": {
      "$type": "number",
      "$value": 16
    },
    "xl": {
      "$type": "number",
      "$value": 24
    }
  },
  "shadow": {
    "none": { "$type": "shadow", "$value": "none" },
    "xs":   { "$type": "shadow", "$value": "0 1px 2px 0 rgba(0,0,0,0.05)" },
    "sm":   { "$type": "shadow", "$value": "0 1px 3px 0 rgba(0,0,0,0.10), 0 1px 2px -1px rgba(0,0,0,0.10)" },
    "md":   { "$type": "shadow", "$value": "0 4px 6px -1px rgba(0,0,0,0.10), 0 2px 4px -2px rgba(0,0,0,0.10)" },
    "lg":   { "$type": "shadow", "$value": "0 10px 15px -3px rgba(0,0,0,0.10), 0 4px 6px -4px rgba(0,0,0,0.10)" },
    "xl":   { "$type": "shadow", "$value": "0 20px 25px -5px rgba(0,0,0,0.10), 0 8px 10px -6px rgba(0,0,0,0.10)" },
    "2xl":  { "$type": "shadow", "$value": "0 25px 50px -12px rgba(0,0,0,0.25)" },
    "inner": { "$type": "shadow", "$value": "inset 0 2px 4px 0 rgba(0,0,0,0.06)" }
  }
}
