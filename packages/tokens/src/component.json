{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "button": {
  "radius": { "$type": "number", "$value": "{radius.md}" },
  "gap":    { "$type": "number", "$value": "{spacing.2}" },
  "padding-x": {
    "sm": { "$type": "number", "$value": "{spacing.3}" },
    "md": { "$type": "number", "$value": "{spacing.4}" },
    "lg": { "$type": "number", "$value": "{spacing.6}" }
  },
  "padding-y": {
    "sm": { "$type": "number", "$value": "{spacing.1}" },
    "md": { "$type": "number", "$value": "{spacing.2}" },
    "lg": { "$type": "number", "$value": "{spacing.3}" }
  },
  "height": {
    "sm": { "$type": "number", "$value": "{spacing.8}" },
    "md": { "$type": "number", "$value": "{spacing.10}" },
    "lg": { "$type": "number", "$value": "{spacing.12}" }
  },
  "font-size": {
    "sm": { "$type": "number", "$value": "{fontSize.sm}" },
    "md": { "$type": "number", "$value": "{fontSize.base}" },
    "lg": { "$type": "number", "$value": "{fontSize.lg}" }
  },
  "primary": {
    "bg":              { "$type": "color", "$value": "{interactive.primary}" },
    "bg-hover":        { "$type": "color", "$value": "{interactive.primary-hover}" },
    "bg-active":       { "$type": "color", "$value": "{interactive.primary-active}" },
    "bg-disabled":     { "$type": "color", "$value": "{interactive.primary-disabled}" },
    "text":            { "$type": "color", "$value": "{text.inverse}" },
    "text-disabled":   { "$type": "color", "$value": "{text.disabled}" },
    "border":          { "$type": "color", "$value": "{interactive.primary}" },
    "border-hover":    { "$type": "color", "$value": "{interactive.primary-hover}" },
    "border-disabled": { "$type": "color", "$value": "{interactive.primary-disabled}" }
  },
  "secondary": {
    "bg":              { "$type": "color", "$value": "{interactive.secondary}" },
    "bg-hover":        { "$type": "color", "$value": "{interactive.secondary-hover}" },
    "bg-active":       { "$type": "color", "$value": "{interactive.secondary-active}" },
    "bg-disabled":     { "$type": "color", "$value": "{interactive.secondary-disabled}" },
    "text":            { "$type": "color", "$value": "{text.secondary}" },
    "text-disabled":   { "$type": "color", "$value": "{text.disabled}" },
    "border":          { "$type": "color", "$value": "{border.default}" },
    "border-hover":    { "$type": "color", "$value": "{border.strong}" },
    "border-disabled": { "$type": "color", "$value": "{border.muted}" }
  },
  "destructive": {
    "bg":              { "$type": "color", "$value": "{interactive.destructive}" },
    "bg-hover":        { "$type": "color", "$value": "{interactive.destructive-hover}" },
    "bg-active":       { "$type": "color", "$value": "{interactive.destructive-active}" },
    "bg-disabled":     { "$type": "color", "$value": "{interactive.primary-disabled}" },
    "text":            { "$type": "color", "$value": "{text.inverse}" },
    "text-disabled":   { "$type": "color", "$value": "{text.disabled}" },
    "border":          { "$type": "color", "$value": "{interactive.destructive}" },
    "border-hover":    { "$type": "color", "$value": "{interactive.destructive-hover}" },
    "border-disabled": { "$type": "color", "$value": "{interactive.primary-disabled}" }
  },
  "ghost": {
    "bg":              { "$type": "color", "$value": "{color.transparent}" },
    "bg-hover":        { "$type": "color", "$value": "{interactive.secondary-hover}" },
    "bg-active":       { "$type": "color", "$value": "{interactive.secondary-active}" },
    "bg-disabled":     { "$type": "color", "$value": "{color.transparent}" },
    "text":            { "$type": "color", "$value": "{text.primary}" },
    "text-hover":      { "$type": "color", "$value": "{text.primary}" },
    "text-disabled":   { "$type": "color", "$value": "{text.disabled}" },
    "border":          { "$type": "color", "$value": "{color.transparent}" },
    "border-hover":    { "$type": "color", "$value": "{border.default}" },
    "border-disabled": { "$type": "color", "$value": "{color.transparent}" }
  },
  "focus-ring-color": { "$type": "color",  "$value": "{focus.ring-color}" },
  "focus-ring-width": { "$type": "number", "$value": "{focus.ring-width}" }
},
  "success": {
    "bg":              { "$type": "color", "$value": "{interactive.success}" },
    "bg-hover":        { "$type": "color", "$value": "{interactive.success-hover}" },
    "bg-active":       { "$type": "color", "$value": "{interactive.success-active}" },
    "bg-disabled":     { "$type": "color", "$value": "{interactive.primary-disabled}" },
    "text":            { "$type": "color", "$value": "{text.inverse}" },
    "text-disabled":   { "$type": "color", "$value": "{text.disabled}" },
    "border":          { "$type": "color", "$value": "{interactive.success}" },
    "border-hover":    { "$type": "color", "$value": "{interactive.success-hover}" },
    "border-disabled": { "$type": "color", "$value": "{interactive.primary-disabled}" }
  },
  "warning": {
    "bg":              { "$type": "color", "$value": "{interactive.warning}" },
    "bg-hover":        { "$type": "color", "$value": "{interactive.warning-hover}" },
    "bg-active":       { "$type": "color", "$value": "{interactive.warning-active}" },
    "bg-disabled":     { "$type": "color", "$value": "{interactive.primary-disabled}" },
    "text":            { "$type": "color", "$value": "{text.inverse}" },
    "text-disabled":   { "$type": "color", "$value": "{text.disabled}" },
    "border":          { "$type": "color", "$value": "{interactive.warning}" },
    "border-hover":    { "$type": "color", "$value": "{interactive.warning-hover}" },
    "border-disabled": { "$type": "color", "$value": "{interactive.primary-disabled}" }
  },
  "input": {
    "padding-x": { "$type": "number", "$value": "{spacing.3}" },
    "padding-y": { "$type": "number", "$value": "{spacing.2}" },
    "font-size": { "$type": "number", "$value": "{fontSize.base}" },
    "radius": { "$type": "number", "$value": "{radius.md}" },
    "border-width": { "$type": "number", "$value": "{borderWidth.1}" },
    "height": {
      "sm": { "$type": "number", "$value": "{spacing.8}" },
      "md": { "$type": "number", "$value": "{spacing.10}" },
      "lg": { "$type": "number", "$value": "{spacing.12}" }
    }
  },
  "card": {
    "radius": { "$type": "number", "$value": "{radius.lg}" },
    "padding": {
      "sm": { "$type": "number", "$value": "{spacing.4}" },
      "md": { "$type": "number", "$value": "{spacing.6}" },
      "lg": { "$type": "number", "$value": "{spacing.8}" }
    }
  },
  "modal": {
    "padding": { "$type": "number", "$value": "{spacing.6}" },
    "radius": { "$type": "number", "$value": "{radius.xl}" },
    "width": {
      "sm": { "$type": "number", "$value": 400 },
      "md": { "$type": "number", "$value": 560 },
      "lg": { "$type": "number", "$value": 720 },
      "xl": { "$type": "number", "$value": 960 }
    }
  },
  "icon": {
    "size": {
      "xs": { "$type": "number", "$value": "{spacing.3}" },
      "sm": { "$type": "number", "$value": "{spacing.4}" },
      "md": { "$type": "number", "$value": "{spacing.5}" },
      "lg": { "$type": "number", "$value": "{spacing.6}" },
      "xl": { "$type": "number", "$value": "{spacing.8}" }
    }
  },
  "avatar": {
    "radius": { "$type": "number", "$value": "{radius.full}" },
    "size": {
      "xs": { "$type": "number", "$value": "{spacing.6}" },
      "sm": { "$type": "number", "$value": "{spacing.8}" },
      "md": { "$type": "number", "$value": "{spacing.10}" },
      "lg": { "$type": "number", "$value": "{spacing.12}" },
      "xl": { "$type": "number", "$value": "{spacing.16}" }
    }
  },
  "badge": {
    "padding-x": { "$type": "number", "$value": "{spacing.2}" },
    "padding-y": { "$type": "number", "$value": "{spacing.1}" },
    "font-size": { "$type": "number", "$value": "{fontSize.xs}" },
    "radius": { "$type": "number", "$value": "{radius.full}" }
  },
  "tooltip": {
    "padding-x": { "$type": "number", "$value": "{spacing.3}" },
    "padding-y": { "$type": "number", "$value": "{spacing.2}" },
    "font-size": { "$type": "number", "$value": "{fontSize.sm}" },
    "radius": { "$type": "number", "$value": "{radius.md}" },
    "max-width": { "$type": "number", "$value": 280 }
  },
  "toast": {
    "padding": { "$type": "number", "$value": "{spacing.4}" },
    "radius": { "$type": "number", "$value": "{radius.lg}" },
    "max-width": { "$type": "number", "$value": 400 }
  }
}
